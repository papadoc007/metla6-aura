{
  "name": "metla6-1-teampulse",
  "version": "1.0.0",
  "description": "TeamPulse — 60-second product video built with Remotion from a JSON brief (Vibe Coding Playbook).",
  "scripts": {
    "dev": "npx remotion studio",
    "build": "npx remotion render src/Root.tsx out/teampulse-60s.mp4 --comp=TeamPulse60s",
    "render-direct": "node render-direct.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@remotion/cli": "4.0.290",
    "remotion": "4.0.290",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@remotion/renderer": "4.0.290",
    "@types/react": "19.0.0",
    "typescript": "^5.4.5"
  }
}
