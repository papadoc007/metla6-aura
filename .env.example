# Copy this file to `.env` and fill in your real values.
# `.env` is ignored by git. Never commit secrets.

# --- Seedance 2.0 video API (used only by the Python backup pipeline) ---
# Sign up at https://seedance2.ai and generate a key.
# Keep the quotes to avoid trailing-whitespace issues.
SEEDANCE_API_KEY="your_seedance_key_here"

# Optional: pick a model. seedance-2-0 is higher quality,
# seedance-2-0-fast is cheaper and quicker.
SEEDANCE_MODEL="seedance-2-0"

# Optional: defaults that the Python client reads.
SEEDANCE_DEFAULT_DURATION="5"
SEEDANCE_DEFAULT_ASPECT="16:9"

# --- Suno (music generation) ---
# Only used if you call Suno's API directly. Not required for
# the Remotion pipeline — the audio track can be mixed in later.
SUNO_API_KEY="your_suno_key_here"
