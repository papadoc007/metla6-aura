# --- Environment & secrets ---
.env
.env.*
!.env.example

# --- Node / Remotion dependencies and build artifacts ---
node_modules/
dist/
build/
.cache/

# --- Remotion render caches ---
.remotion/
.remotion-cache/
*.remotion.json
remotion-render-*/

# --- Python (backup pipeline, mirrors metla5) ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
env/
.python-version
.mypy_cache/
.ruff_cache/
.pytest_cache/

# --- Video / audio output (assignment REQUIRES the final MP4) ---
# We commit only the deliverable MP4 in out/; the assignment booklet
# requires the video to be in the repo. We do NOT commit user-generated
# clips/ (raw Seedance output that we may regenerate).
# Match the literal "output" dir at the root only (avoid matching music/output)
/output/
/clips/
*.mp4
!out/aura-60s.mp4
!out/aura-60s-hq.mp4
!out/aura-preview.mp4
# Re-ignore the placeholder out/ scratch files that are not the final video
out/*.tmp
out/*.log
out/*.json
*.mov
*.webm
*.mkv
*.avi
# Audio: commit the soundtrack MP3s in music/output/ (Suno deliverables)
*.mp3
!music/output/*.mp3
*.wav
*.m4a
*.flac
# out/ itself is NOT ignored — we just exclude non-deliverable files inside it
!/out/

# --- Image / static assets cache ---
*.psd
*.ai
*.sketch

# --- Editors / OS ---
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# --- Screenshots: commit the rendered JPG proofs (not the placeholders) ---
docs/screenshots/*.png
docs/screenshots/*.gif
# But include the 3 rendered frames as proof of execution
!docs/screenshots/04-rendered-frame-1.jpg
!docs/screenshots/05-rendered-frame-2.jpg
!docs/screenshots/06-rendered-frame-3.jpg

# --- Local handoff notes ---
PROJECT_HANDOFF.md

# --- METLA6.1 (TeamPulse) sub-project ---
# Apply the same video/audio/binary rules to the nested 6.1 project.
METLA6.1/node_modules/
METLA6.1/.remotion/
METLA6.1/.remotion-cache/
METLA6.1/dist/
METLA6.1/build/
METLA6.1/.cache/
# Commit the final TeamPulse MP4 deliverable, ignore everything else in its out/
METLA6.1/out/
!METLA6.1/out/.gitkeep
!METLA6.1/out/teampulse-60s.mp4
# Ignore raw audio in 6.1's music/output (Suno intermediate, large)
METLA6.1/music/output/*.mp3
METLA6.1/music/output/*.wav
!METLA6.1/music/output/.gitkeep
# Ignore Python caches from 6.1's fallback pipeline
METLA6.1/python/__pycache__/
METLA6.1/.venv/
